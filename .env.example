# --- MeshCom Listener Configuration ---
LOG_LEVEL=INFO

# --- Listener Settings ---
LISTENER_HOST=0.0.0.0
LISTENER_PORT=1799
STORE_TYPES=msg,pos,tele,status,ack

# --- SurrealDB Settings ---
# In Docker-Compose use 'surrealdb' as hostname
DB_URL=ws://surrealdb:8000
DB_USER=root
DB_PASS=root
DB_NS=meshcom
DB_DB=listener

# --- Notifications (Apprise API) ---
NOTIFY_ENABLED=true
# In Docker-Compose use 'apprise' as hostname
APPRISE_URL=http://apprise:8000/notify
# Example Targets: tgram://bottoken/chatid, mailto://user:pass@gmail.com
NOTIFY_TARGETS=
